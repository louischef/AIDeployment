# Copy this file to .env and fill in your own values. Never commit the real .env.
#
# --- Elasticsearch (Elastic Cloud) ---
# Found on your deployment page at https://cloud.elastic.co/ after creating the
# 14-day trial cluster referenced in the TP (step 5).
ES_CLOUD_ID=
ES_API_KEY=

# Alternative to ES_CLOUD_ID if you are pointing at a self-hosted / local cluster.
# ES_URL=https://localhost:9200

# Name of the index that osint_ner.es_ingest creates/writes to.
ES_INDEX=tass_war_entities
